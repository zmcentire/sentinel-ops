{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "moduleResolution":  "node",
    "esModuleInterop":   true,
    "strict":            true,
    "skipLibCheck":      true,
    "declaration":       true,
    "sourceMap":         true,
    "resolveJsonModule": true
  }
}
