{
    "name": "sentinel-ops",
    "private": true,
    "workspaces": ["packages/*"],
    "scripts": {
        "dev": "concurrently \"npm run dev -w @sentinel/api\" \"npm run dev -w @sentinel/workers\" \"npm run dev -w @sentinel/frontend\"",
        "build:api":     "npm run build -w @sentinel/api",
        "build:workers": "npm run build -w @sentinel/workers",
        "migrate": "node packages/db/migrate.js"
    },
    "devDependencies": {
        "concurrently": "^8.0.0",
        "typescript": "^5.4.0"
    }
}